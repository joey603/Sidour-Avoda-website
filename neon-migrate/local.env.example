# Copier ce fichier vers : local.env
# Remplir les deux URLs (sans guillemets inutiles en fin de ligne).
#
# Optionnel : si pg_dump 17 n’est pas trouvé automatiquement :
# PG17_HOME=/opt/homebrew/opt/postgresql@17
#
# DATABASE_URL_OLD = projet Neon actuel (ex. us-east-1) — connexion directe
#   ou pooler, selon ce que Neon te donne pour un dump fiable.
# DATABASE_URL_NEW = nouveau projet Neon (ex. eu-central-1 pooler).
#
# Si le mot de passe contient des caractères spéciaux, encode-les dans l’URL
# ou utilise un fichier ~/.pgpass (voir doc PostgreSQL).

# Mettre l’URL entre quotes simples si elle contient & (ex. channel_binding=require).
DATABASE_URL_OLD='postgresql://USER:PASSWORD@HOST_OLD/neondb?sslmode=require&channel_binding=require'
DATABASE_URL_NEW='postgresql://USER:PASSWORD@HOST_NEW/neondb?sslmode=require&channel_binding=require'
