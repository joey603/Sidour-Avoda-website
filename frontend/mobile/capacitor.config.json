{
  "appId": "com.giwan.sidour",
  "appName": "גי וואן",
  "webDir": "www",
  "server": {
    "url": "https://sidour-avoda-website.vercel.app",
    "cleartext": false,
    "allowNavigation": [
      "sidour-avoda-website.vercel.app",
      "*.vercel.app",
      "localhost",
      "127.0.0.1"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#ffffff",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#ffffff"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "preferredContentMode": "mobile",
    "backgroundColor": "#ffffff"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#ffffff"
  }
}
